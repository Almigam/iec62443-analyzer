# IEC 62443-3-3 Analyzer - Environment Configuration

# Environment (development/production)
ENV=production

# Server Configuration
PORT=443
HOST=0.0.0.0

# Database
DB_PATH=./data/iec62443.db

# TLS/HTTPS
TLS_CERT=./certs/server.crt
TLS_KEY=./certs/server.key

# JWT Configuration
JWT_SECRET=change-this-to-a-strong-secret-in-production
JWT_EXPIRY=8h

# Allowed Origins (CORS)
ALLOWED_ORIGINS=https://localhost,https://rpi-analyzer

# Logging
LOG_DIR=./logs
LOG_LEVEL=info

# Security
PASSWORD_MIN_LENGTH=12
LOGIN_MAX_ATTEMPTS=3
LOGIN_LOCKOUT_DURATION=1800
SESSION_TIMEOUT=28800

# Resource Limits
MAX_CONNECTIONS=100
READ_TIMEOUT=15s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=60s

# Database
DB_CONNECT_TIMEOUT=5s
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5

# API Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# Monitoring
HEALTH_CHECK_INTERVAL=30s
RESOURCE_CHECK_INTERVAL=60s
LOG_RETENTION_DAYS=30
